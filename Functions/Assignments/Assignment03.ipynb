   "source": [
    "# Write a function to calculate and return the factorial of a number.\n",
    "\n",
    "def factorial(num):\n",
    "    fact = 1\n",
    "    for i in range(1, num + 1):\n",
    "        fact *= i\n",
    "    return fact\n",
    "\n",
    "number = int(input(\"Enter a number: \"))\n",
    "\n",
    "print(\"Factorial =\", factorial(number))"
   ]
