   "source": [
    "# Remove a given item from the set.\n",
    "\n",
    "my_set = {10, 20, 30, 40, 50}\n",
    "\n",
    "item = int(input(\"Enter item to remove: \"))\n",
    "\n",
    "if item in my_set:\n",
    "    my_set.remove(item)\n",
    "    print(\"Updated Set:\", my_set)\n",
    "else:\n",
    "    print(\"Item not found.\")"
   ]
