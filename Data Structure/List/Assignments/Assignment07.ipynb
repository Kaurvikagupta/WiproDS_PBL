    "# Remove the item from a specified index in a list.\n",
    "\n",
    "numbers = [10, 20, 30, 40, 50]\n",
    "\n",
    "index = int(input(\"Enter index to remove: \"))\n",
    "\n",
    "numbers.pop(index)\n",
    "\n",
    "print(\"Updated List:\", numbers)"
