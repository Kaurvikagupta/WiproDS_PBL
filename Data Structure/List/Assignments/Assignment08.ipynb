    "# Remove the first occurrence of a specified element from a list.\n",
    "\n",
    "numbers = [10, 20, 30, 20, 40, 20, 50]\n",
    "\n",
    "element = int(input(\"Enter element to remove: \"))\n",
    "\n",
    "numbers.remove(element)\n",
    "\n",
    "print(\"Updated List:\", numbers)"
   ]
