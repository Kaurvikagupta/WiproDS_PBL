    "# Count how many times the name \"Alex\" appears in a string.\n",
    "\n",
    "text = input(\"Enter a string: \")\n",
    "\n",
    "count = text.count(\"Alex\")\n",
    "\n",
    "print(\"Number of times Alex appears:\", count)"
