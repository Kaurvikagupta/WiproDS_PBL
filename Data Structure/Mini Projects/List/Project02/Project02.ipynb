   "source": [
    "# Find the runner-up score from a list of participant scores.\n",
    "\n",
    "scores = [2, 3, 6, 6, 5]\n",
    "\n",
    "unique_scores = list(set(scores))\n",
    "\n",
    "unique_scores.sort()\n",
    "\n",
    "print(\"Runner-up score:\", unique_scores[-2])"
   ]
