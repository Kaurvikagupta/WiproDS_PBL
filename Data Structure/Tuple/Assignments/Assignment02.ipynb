    "# Check whether an element exists in a tuple or not.\n",
    "\n",
    "numbers = (10, 20, 30, 40, 50)\n",
    "\n",
    "element = int(input(\"Enter element to search: \"))\n",
    "\n",
    "if element in numbers:\n",
    "    print(\"Element exists.\")\n",
    "else:\n",
    "    print(\"Element does not exist.\")"
   ]
