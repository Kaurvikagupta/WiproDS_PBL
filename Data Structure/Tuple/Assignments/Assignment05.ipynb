   "source": [
    "# Replace the last value of tuples in a list with 100.\n",
    "\n",
    "list_of_tuples = [(10, 20, 40), (40, 50, 60), (70, 80, 90)]\n",
    "\n",
    "result = []\n",
    "\n",
    "for item in list_of_tuples:\n",
    "    result.append(item[:-1] + (100,))\n",
    "\n",
    "print(result)"
   ]
