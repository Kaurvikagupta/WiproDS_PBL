    "# Find the index of an item in a tuple.\n",
    "\n",
    "numbers = (10, 20, 30, 40, 50)\n",
    "\n",
    "element = int(input(\"Enter element: \"))\n",
    "\n",
    "if element in numbers:\n",
    "    print(\"Index:\", numbers.index(element))\n",
    "else:\n",
    "    print(\"Element not found.\")"
   ]
