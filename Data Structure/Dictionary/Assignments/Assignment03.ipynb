   "source": [
    "# Check if a given key already exists in a dictionary.\n",
    "\n",
    "dictionary = {1: \"Apple\", 2: \"Banana\", 3: \"Mango\"}\n",
    "\n",
    "key = int(input(\"Enter key: \"))\n",
    "\n",
    "if key in dictionary:\n",
    "    print(\"Key exists.\")\n",
    "else:\n",
    "    print(\"Key does not exist.\")"
   ]
