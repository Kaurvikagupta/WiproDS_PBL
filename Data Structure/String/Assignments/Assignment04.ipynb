   "source": [
    "# Remove 'x' from the first or last position of a string.\n",
    "\n",
    "string = input(\"Enter a string: \")\n",
    "\n",
    "if string.startswith('x'):\n",
    "    string = string[1:]\n",
    "\n",
    "if string.endswith('x'):\n",
    "    string = string[:-1]\n",
    "\n",
    "print(string)"
   ]
