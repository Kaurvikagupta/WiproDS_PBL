   "source": [
    "# Return a new string made of n copies of the first 2 characters.\n",
    "\n",
    "string = input(\"Enter a string: \")\n",
    "\n",
    "n = len(string)\n",
    "\n",
    "result = string[:2] * n\n",
    "\n",
    "print(result)"
