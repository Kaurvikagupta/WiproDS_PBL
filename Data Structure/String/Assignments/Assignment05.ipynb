   "source": [
    "# Return a string made of n repetitions of the last n characters.\n",
    "\n",
    "string = input(\"Enter a string: \")\n",
    "n = int(input(\"Enter n: \"))\n",
    "\n",
    "result = string[-n:] * n\n",
    "\n",
    "print(result)"
