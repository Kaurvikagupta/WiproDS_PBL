    "#Check if two numbers have the same last digit\n",
    "\n",
    "num1= int(input(\"Enter first number: \"))\n",
    "num2= int(input(\"Enter second number: \"))\n",
    "\n",
    "if num1% 10== num2% 10:\n",
    "    print(\"true\")\n",
    "else:\n",
    "    print(\"false\")"
