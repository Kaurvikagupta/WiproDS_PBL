   ],
   "source": [
    "# Print the sum of all digits of a given number\n",
    "\n",
    "num = int(input(\"Enter a number: \"))\n",
    "sum_digits = 0\n",
    "\n",
    "while num > 0:\n",
    "    digit = num % 10\n",
    "    sum_digits += digit\n",
    "    num //= 10\n",
    "\n",
    "print(\"Sum of digits =\", sum_digits)"
   ]
  },
