   "source": [
    "# Print all prime numbers between 10 and 99\n",
    "\n",
    "for num in range(10, 100):\n",
    "    for i in range(2, int(num**0.5) + 1):\n",
    "        if num % i == 0:\n",
    "            break\n",
    "    else:\n",
    "        print(num)"
   ]
