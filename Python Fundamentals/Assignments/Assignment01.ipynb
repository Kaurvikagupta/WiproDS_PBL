    "# Program to check whether a number is Positive, Negative, or Zero\n",
    "num= float(input(\"Enter a number: \"))\n",
    "\n",
    "if num>0:\n",
    " print(\"positive number\")\n",
    "elif num<0:\n",
    " print(\"Negative number\")\n",
    "else:\n",
    " print(\"Zero\")   "
