   ],
   "source": [
    "file_name = input(\"Enter file name: \")\n",
    "word = input(\"Enter the word to search: \")\n",
    "\n",
    "with open(file_name, \"r\") as file:\n",
    "    text = file.read().lower()\n",
    "\n",
    "count = text.split().count(word.lower())\n",
    "\n",
    "print(\"Frequency of\", word, \"is\", count)"
   ]
