   "source": [
    "file_name = input(\"Enter file name: \")\n",
    "n = int(input(\"Enter number of lines: \"))\n",
    "\n",
    "with open(file_name, \"r\") as file:\n",
    "    for i in range(n):\n",
    "        line = file.readline()\n",
    "\n",
    "        if not line:\n",
    "            break\n",
    "\n",
    "        print(line, end=\"\")"
   ]
