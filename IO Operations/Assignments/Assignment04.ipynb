   "source": [
    "file_name = input(\"Enter file name: \")\n",
    "\n",
    "with open(file_name, \"r\") as file:\n",
    "    lines = file.readlines()\n",
    "\n",
    "lines = [line.strip() for line in lines]\n",
    "\n",
    "print(\"List of lines:\")\n",
    "print(lines)"
